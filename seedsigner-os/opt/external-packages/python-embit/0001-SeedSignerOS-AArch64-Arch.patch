From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
Subject: [PATCH] SeedSignerOS: Add comment for arch patch compatibility

Adds a harmless comment to pyproject.toml in a section not modified by the
arch-selection patch. The actual arch-specific prebuilt selection for
aarch64 is handled via PYTHON_EMBIT_POST_PATCH_HOOKS in python-embit.mk.
---
 pyproject.toml | 1 +
 1 file changed, 1 insertion(+)

diff --git a/pyproject.toml b/pyproject.toml
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,3 +1,4 @@
+# SeedSignerOS
 [build-system]
 requires = ["setuptools>=42.0", "wheel"]
 build-backend = "setuptools.build_meta"
-- 
